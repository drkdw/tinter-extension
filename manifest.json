{
  "manifest_version": 3,
  "name": "Tinter - Color Palette Generator",
  "version": "1.0.1",
  "description": "Generate color shades, tints, and CSS variables from any hex color. Includes color harmonies: complementary, analogous, triadic.",
  "author": "Dirk De Wever",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tinter - Color Palette Generator"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.thecolorapi.com/*"
  ]
}
